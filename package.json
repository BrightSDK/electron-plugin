{
  "name": "electron-bright-sdk",
  "version": "1.0.1",
  "description": "Node.js native addon for integrating Bright Data SDK in Electron applications",
  "main": "brd_sdk.js",
  "gypfile": true,
  "napi": true,
  "scripts": {
    "install": "node-gyp rebuild --arch=x64",
    "rebuild": "node-gyp rebuild --arch=x64"
  },
  "build": {
    "files": [
      "node_modules/electron-bright-sdk/build/Release/*.node"
    ],
    "extraResources": [
      {
        "from": "sdk_dist",
        "to": "sdk"
      }
    ],
    "asarUnpack": [
      "node_modules/electron-bright-sdk/build/Release/*.node",
      "node_modules/electron-bright-sdk/sdk_dist/**"
    ]
  },
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {}
}
